#include <stdio.h>
#include <locale.h>

int main(){
	setlocale(LC_ALL, "Portuguese");
   int a;
   int b;
   int aux;
   
   printf("Digite o valor de A: \n");
   scanf("%d", &a);
   
   printf("Digite o valor de B: \n");
   scanf("%d", &b);
   
   aux = a;
   a = b;
   b = aux;
  
   printf("O valor de A agora é: %d \n", a);
   printf("O valor de B agora é: %d \n", b);

   return 0;       
}
