#include <stdio.h>
#include <locale.h>

int main() {
    setlocale(LC_ALL, "Portuguese");
    float precofab;
    float impostos = 0.45;
    float revendedor = 0.28;
    float aux;
    float aux1;
    float precofinal;
    
    printf("Digite o preço de fábrica do automóvel: \n");
    scanf("%f", &precofab);
    
    aux = precofab * impostos;
    aux1 = precofab * revendedor;
    precofinal = precofab + aux + aux1;
    
    printf("O preço final do seu automóvel é: %.2f \n", precofinal);
    
    
    
    
    
    return 0;
}
